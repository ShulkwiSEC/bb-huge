# Copy this to .env and fill in your values
# bb-huge environment configuration

# REQUIRED — change before first run!
SECRET_KEY=super-secret-flask-key-change-me
DEV_KEY=bb-huge-dev-key-change-me

# Optional overrides
FLASK_PORT=5000
FLASK_DEBUG=0

# MCP server (if running HTTP mode)
MCP_HOST=127.0.0.1
MCP_PORT=5001

# BB_HUGE_URL used by mcp_server.py and bb.py helper
BB_HUGE_URL=http://127.0.0.1:5000
